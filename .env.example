# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit real keys.

# Required: predict.fun API key
PREDICT_API_KEY=

# Optional: defaults to https://api.predict.fun
PREDICT_API_BASE=

# Optional: upstream request timeout in ms (default 15000)
PROXY_TIMEOUT_MS=

# Optional: exact origin allowed to call the proxy cross-site.
# Leave empty for same-origin only (recommended).
ALLOWED_ORIGIN=
